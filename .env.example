# ================================
# VedShare — Backend Environment Variables
# ================================
# Copy this file as .env and fill in real values

PORT=5001

# MongoDB Atlas
DB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# Upstash Redis (optional — app works without it)
UPSTASH_REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# JWT Secrets (use strong random strings, e.g. openssl rand -hex 32)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Mailjet (OTP & transactional emails)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key

# Cloudinary (image/file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxxxx

# Client URL (your Vercel frontend URL in production)
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# reCAPTCHA v3 (optional)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Firebase Admin SDK (Google Auth)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
